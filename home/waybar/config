{
  "layer": "top",
  "position": "top",
  "height": 38,
  "margin-top": 8,
  "margin-left": 16,
  "margin-right": 16,
  "spacing": 0,
  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["custom/gpu", "cpu", "memory", "temperature", "pulseaudio", "network", "tray"],
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "󰲠",
      "2": "󰲢",
      "3": "󰲤",
      "4": "󰲦",
      "5": "󰲨",
      "6": "󰲪",
      "7": "󰲬",
      "8": "󰲮",
      "9": "󰲰",
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 60,
    "separate-outputs": false
  },
  "clock": {
    "format": "󰃰  {:%H:%M}",
    "format-alt": "  {:%A, %d de %B de %Y}",
    "locale": "es_AR.UTF-8",
    "tooltip-format": "<big>{:%A %d/%m/%Y}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "cpu": {
    "format": "  {usage}%",
    "interval": 2,
    "on-click": "ghostty -e htop"
  },
  "memory": {
    "format": "  {percentage}%",
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G",
    "interval": 2
  },
  "temperature": {
    "critical-threshold": 85,
    "format": "  {temperatureC}°",
    "format-critical": "  {temperatureC}°"
  },
  "pulseaudio": {
    "format": "󰕾  {volume}%",
    "format-muted": "󰖁  mute",
    "format-bluetooth": "󰂰  {volume}%",
    "on-click": "pavucontrol",
    "scroll-step": 5
  },
  "network": {
    "format-wifi": "󰖩  {essid}",
    "format-ethernet": "󰈀  {ipaddr}",
    "format-disconnected": "󰤮  sin red",
    "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n{bandwidthUpBits} ↑  {bandwidthDownBits} ↓"
  },
  "custom/gpu": {
    "exec": "cat /sys/class/drm/card*/device/gpu_busy_percent 2>/dev/null | head -1 | awk '{printf \"󰾲  %d%%\", $1}' || echo '󰾲  -'",
    "interval": 2,
    "tooltip": false
  },
  "tray": {
    "spacing": 10,
    "icon-size": 16
  }
}
